# ── Tyk Console ── Environment Variables ──
# Copy this file to .env and fill in your values.

# ── PostgreSQL ──
PG_DSN=postgresql://ichse:change_me@localhost:5433/ichse
POSTGREST_URL=http://localhost:3001
PGRST_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Redis ──
REDIS_URL=redis://localhost:6380/0

# ── Tyk Gateway ──
TYK_URL=http://localhost:8080

# ── App ──
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Frontend (Vite) ──
VITE_POSTGREST_URL=http://localhost:3001
VITE_SERVICES_URL=http://localhost:8000
VITE_TYK_URL=http://localhost:8080
